# Copy this to .env for development and .env.production for production.
# Never commit real values to git.

# Database
DATABASE_URL=postgres://hatiwal:password@localhost:5407/hatiwal_development

# Redis
REDIS_URL=redis://localhost:6307/0

# Auth
DEVISE_JWT_SECRET_KEY=change_me_run_rails_secret

# Kamal / Docker Registry (production only)
KAMAL_HOST=your-server-ip
KAMAL_PROXY_HOST=api.hatiwal.com
KAMAL_REGISTRY_USERNAME=hama99o
KAMAL_REGISTRY_PASSWORD=your-dockerhub-token
DATABASE_PASSWORD=strong-db-password
APP_DOMAIN=api.hatiwal.com

# SSH (production only)
SSH_USER=kamal
SSH_KEY_PATH=~/.ssh/id_ed25519

# Active Storage (set to amazon for S3)
ACTIVE_STORAGE_SERVICE=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET=
# AWS_REGION=

# Email (Postmark — same service as MultiMagic)
# Get your token at https://account.postmarkapp.com/servers
POSTMARK_API_TOKEN=your-postmark-server-token
MAILER_FROM=noreply@hatiwal.com

# Password reset URL — where the mobile app / web sends users after clicking the email link.
# For mobile-only deployments point this at the Hatiwal web app (if it exists)
# or use a deep-link base URL for the mobile app.
WEB_RESET_URL=https://hatiwal.com/reset-password

# Google OAuth (for "Sign in with Google" in the mobile app)
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
# Use an "Android" + "iOS" OAuth 2.0 client (NOT a Web client) for the mobile app.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Copy this to .env for development and .env.production for production.
# Never commit real values to git.

# Database
DATABASE_URL=postgres://hatiwal:password@localhost:5407/hatiwal_development

# Redis
REDIS_URL=redis://localhost:6307/0

# Auth
DEVISE_JWT_SECRET_KEY=change_me_run_rails_secret

# Kamal / Docker Registry (production only)
KAMAL_HOST=your-server-ip
KAMAL_PROXY_HOST=api.hatiwal.com
KAMAL_REGISTRY_USERNAME=hama99o
KAMAL_REGISTRY_PASSWORD=your-dockerhub-token
DATABASE_PASSWORD=strong-db-password
APP_DOMAIN=api.hatiwal.com

# SSH (production only)
SSH_USER=kamal
SSH_KEY_PATH=~/.ssh/id_ed25519

# Active Storage (set to amazon for S3)
ACTIVE_STORAGE_SERVICE=local

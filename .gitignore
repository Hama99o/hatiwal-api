# ── Secrets & credentials ───────────────────────────────────────────────────
.env
.env.*
!.env.example
/config/master.key
/config/credentials/*.key
/.kamal/secrets
/config/database.yml.local

# ── Bundler ──────────────────────────────────────────────────────────────────
/.bundle
/vendor/bundle

# ── Logs & tmp ───────────────────────────────────────────────────────────────
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
/tmp/pids/*
!/tmp/pids/.keep

# ── Storage (uploaded files, SQLite DBs) ─────────────────────────────────────
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/.keep

# ── Test artifacts ────────────────────────────────────────────────────────────
/coverage/
/spec/reports/

# ── Node (if any JS tooling is added) ────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Capistrano deploy overrides ───────────────────────────────────────────────
/config/deploy.rb
/config/deploy/

# ── Compiled assets (if asset pipeline is used) ───────────────────────────────
/public/assets
/public/packs
/public/packs-test

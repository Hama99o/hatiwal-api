<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Password Reset — Hatiwal</title>
</head>
<body style="margin:0;padding:0;background-color:#0f172a;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#0f172a;padding:40px 0;">
    <tr>
      <td align="center">
        <table width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:560px;">

          <!-- Header -->
          <tr>
            <td align="center" style="padding-bottom:24px;">
              <span style="font-size:20px;font-weight:700;color:#e2e8f0;letter-spacing:-0.5px;">Hatiwal Admin</span>
            </td>
          </tr>

          <!-- Card -->
          <tr>
            <td style="background:#1e293b;border-radius:12px;padding:40px 48px;border:1px solid #334155;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0">

                <tr>
                  <td align="center" style="padding-bottom:24px;">
                    <div style="width:52px;height:52px;border-radius:50%;background-color:#312e81;display:inline-block;text-align:center;line-height:52px;font-size:24px;">&#128274;</div>
                  </td>
                </tr>

                <tr>
                  <td align="center">
                    <h1 style="margin:0 0 8px;font-size:20px;font-weight:700;color:#e2e8f0;">Reset your admin password</h1>
                    <p style="margin:0 0 24px;font-size:14px;color:#94a3b8;">A password reset was requested for this admin account.</p>
                  </td>
                </tr>

                <tr>
                  <td style="padding:0 0 24px;">
                    <p style="margin:0;font-size:14px;color:#cbd5e1;line-height:1.6;">Hi <strong><%= @admin_user.name.presence || @admin_user.email %></strong>,</p>
                    <p style="margin:12px 0 0;font-size:14px;color:#cbd5e1;line-height:1.6;">Click the button below to set a new password. This link expires in <strong>6 hours</strong>.</p>
                  </td>
                </tr>

                <tr>
                  <td align="center" style="padding:8px 0 28px;">
                    <a href="<%= @reset_url %>" style="display:inline-block;padding:13px 32px;background-color:#6366f1;color:#ffffff;font-size:14px;font-weight:600;text-decoration:none;border-radius:8px;">Reset Password</a>
                  </td>
                </tr>

                <tr>
                  <td style="padding-bottom:24px;">
                    <p style="margin:0;font-size:12px;color:#64748b;line-height:1.6;">If the button doesn&rsquo;t work, paste this URL into your browser:</p>
                    <p style="margin:6px 0 0;font-size:12px;"><a href="<%= @reset_url %>" style="color:#818cf8;word-break:break-all;"><%= @reset_url %></a></p>
                  </td>
                </tr>

                <tr>
                  <td style="border-top:1px solid #334155;padding-top:20px;">
                    <p style="margin:0;font-size:12px;color:#64748b;line-height:1.6;">If you didn&rsquo;t request this, ignore this email — your password won&rsquo;t change.</p>
                  </td>
                </tr>

              </table>
            </td>
          </tr>

          <tr>
            <td align="center" style="padding-top:24px;">
              <p style="margin:0;font-size:12px;color:#475569;">&copy; <%= Time.current.year %> Hatiwal. Staff use only.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>

<%# A prominent "Account moderation" panel on top of the default Administrate
    user show page. Blocking bans the account (rejected by the API) with a reason
    that is shown to the user; unblocking restores it. %>

<section style="margin:0 0 1.5rem;padding:1.25rem 1.5rem;border:1px solid #fca5a5;border-radius:12px;background:#fef2f2;">
  <h2 style="margin:0 0 .5rem;font-size:1.05rem;color:#991b1b;">🚫 Account moderation</h2>

  <% if page.resource.account_blocked? %>
    <p style="margin:0 0 .9rem;color:#7f1d1d;">
      This account is <strong><%= page.resource.status.upcase %></strong> — the user
      cannot log in and is told they are blocked.
      <% if page.resource.block_reason.present? %>
        <br>Reason given: <em><%= page.resource.block_reason %></em>
      <% end %>
    </p>
    <%= button_to "Unblock user", unblock_admin_user_path(page.resource),
          method: :patch, data: { turbo: false }, class: "button" %>
  <% else %>
    <p style="margin:0 0 .9rem;color:#7f1d1d;">
      Blocking bans this user from the whole app. They’ll be unable to log in and
      will see the reason you enter below.
    </p>
    <%= form_with url: block_admin_user_path(page.resource), method: :patch,
          data: { turbo: false },
          style: "display:flex;gap:.6rem;align-items:center;flex-wrap:wrap;" do |f| %>
      <%= f.text_field :block_reason, placeholder: "Reason shown to the user (optional)",
            style: "flex:1;min-width:260px;padding:.55rem .7rem;border:1px solid #cbd5e1;border-radius:6px;" %>
      <%= f.submit "Block user", class: "button button--danger",
            data: { confirm: "Block #{page.resource.full_name}? They will be signed out and told they are blocked." } %>
    <% end %>
  <% end %>
</section>

<%= render template: "administrate/application/show", locals: { page: page } %>

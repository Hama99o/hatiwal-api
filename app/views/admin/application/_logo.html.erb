<%#
# Hatiwal brand mark — a lapis tile with the white "H" monogram + gold crossbar.
# Matches the mobile app icon and the web header logo (one brand everywhere).
# Local: `size` (px). The gradient id is suffixed with size to stay unique when
# the mark appears more than once on a page.
%>
<% gid = "hatiwalLapis#{size}" %>
<svg width="<%= size %>" height="<%= size %>" viewBox="0 0 100 100"
     role="img" aria-label="Hatiwal" style="display:block;flex:none;">
  <defs>
    <radialGradient id="<%= gid %>" cx="32%" cy="24%" r="90%">
      <stop offset="0%" stop-color="#3A63D6"/>
      <stop offset="100%" stop-color="#102049"/>
    </radialGradient>
  </defs>
  <rect width="100" height="100" rx="24" fill="url(#<%= gid %>)"/>
  <g fill="none" stroke-linecap="round">
    <path d="M33.5 27V73M66.5 27V73" stroke="#F7F4EC" stroke-width="13.5"/>
    <path d="M33.5 49H66.5" stroke="#E8B23A" stroke-width="13.5"/>
  </g>
</svg>

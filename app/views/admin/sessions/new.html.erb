<%= form_for(@admin_user, as: :admin_user, url: admin_user_session_path) do |f| %>
  <%= label_tag "admin_user_email", "Email" %>
  <%= email_field_tag "admin_user[email]", @admin_user.email,
        id: "admin_user_email", autocomplete: "username", autofocus: true, required: true %>

  <%= label_tag "admin_user_password", "Password" %>
  <%= password_field_tag "admin_user[password]", nil,
        id: "admin_user_password", autocomplete: "current-password", required: true %>

  <%= submit_tag "Sign in" %>
<% end %>

<p style="text-align:center;margin-top:1.25rem;font-size:.85rem;opacity:.65;">
  <%= link_to "Forgot your password?", new_admin_user_password_path, style: "color:#a5b4fc;text-decoration:none;" %>
</p>

<% if Rails.application.credentials[:google_client_id].present? %>
  <div style="margin-top:1.5rem;display:flex;align-items:center;gap:.75rem;">
    <hr style="flex:1;border:none;border-top:1px solid rgba(255,255,255,.15);" />
    <span style="font-size:.8rem;opacity:.5;white-space:nowrap;">or</span>
    <hr style="flex:1;border:none;border-top:1px solid rgba(255,255,255,.15);" />
  </div>

  <%= link_to admin_google_auth_initiate_path,
        style: "display:flex;align-items:center;justify-content:center;gap:.6rem;margin-top:1rem;
                padding:.65rem 1rem;border-radius:.5rem;font-size:.9rem;font-weight:500;
                background:#fff;color:#1f2937;text-decoration:none;
                border:1px solid rgba(255,255,255,.2);transition:opacity .15s;" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48">
      <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
      <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
      <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
      <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
      <path fill="none" d="M0 0h48v48H0z"/>
    </svg>
    Sign in with Google
  <% end %>
<% end %>

<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="initial-scale=1">
  <meta name="ROBOTS" content="NOINDEX, NOFOLLOW">
  <title>Admin sign in — Hatiwal</title>
  <link rel="icon" type="image/svg+xml" href="/icon.svg">
  <link rel="alternate icon" href="/favicon.ico">
  <%= csrf_meta_tags %>
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #0f172a; color: #e2e8f0; margin: 0;
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
    }
    .auth-card {
      background: #1e293b; padding: 2.5rem; border-radius: 14px;
      width: 100%; max-width: 360px; box-shadow: 0 20px 50px rgba(0,0,0,.4);
    }
    .auth-card h1 { margin: 0 0 0.25rem; font-size: 1.4rem; }
    .auth-card p.sub { margin: 0 0 1.5rem; font-size: .85rem; opacity: .65; }
    label { display: block; font-size: .8rem; margin: 0 0 .35rem; opacity: .85; }
    input[type=email], input[type=password] {
      width: 100%; padding: .7rem .8rem; margin-bottom: 1rem;
      border: 1px solid #334155; border-radius: 8px;
      background: #0f172a; color: #e2e8f0; font-size: .95rem;
    }
    button {
      width: 100%; padding: .75rem; border: 0; border-radius: 8px;
      background: #6366f1; color: #fff; font-size: .95rem; font-weight: 600; cursor: pointer;
    }
    button:hover { background: #4f46e5; }
    .flash { padding: .65rem .8rem; border-radius: 8px; margin-bottom: 1rem; font-size: .85rem; }
    .flash--alert { background: #7f1d1d; color: #fecaca; }
    .flash--notice { background: #14532d; color: #bbf7d0; }
    .remember { display: flex; align-items: center; gap: .5rem; margin-bottom: 1.25rem; font-size: .85rem; }
    .remember input { margin: 0; }
  </style>
</head>
<body>
  <div class="auth-card">
    <div style="display:flex;justify-content:center;margin-bottom:1rem;">
      <%= render "admin/application/logo", size: 56 %>
    </div>
    <h1 style="text-align:center;">Hatiwal Admin</h1>
    <p class="sub" style="text-align:center;">Staff access only</p>

    <% if flash[:alert] %><div class="flash flash--alert"><%= flash[:alert] %></div><% end %>
    <% if flash[:notice] %><div class="flash flash--notice"><%= flash[:notice] %></div><% end %>

    <%= yield %>
  </div>
</body>
</html>
